# ── BASE DE DONNÉES ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/mustech

# ── SERVEUR ───────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-domain.up.railway.app

# ── JWT ───────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=votre_secret_jwt_tres_long_et_aleatoire

# ── ADMIN (OBLIGATOIRE au premier démarrage) ───────────────
# Ces variables sont REQUISES si aucun utilisateur n'existe en base.
# Ne jamais mettre de valeurs par défaut dans le code !
ADMIN_EMAIL=admin@votresite.com
ADMIN_PASSWORD=MotDePasseAdmin_TresSecure_2024!
ADMIN_PHONE=0555000000   # optionnel

# ── CLOUDINARY ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
